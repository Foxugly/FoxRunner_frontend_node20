# Node 20 compatibility fork.
# Some transitive dev tooling (e.g. a nested eslint-visitor-keys) declares an
# engines range that excludes Node 20.14.0 (it wants >= 20.19). npm's default is
# to treat that as a warning, but if the host has a global `engine-strict=true`
# (some locked-down corporate setups do), `npm ci` would fail. Pin it false here
# so the project installs cleanly on the IT-locked Node 20.14.0 machine. The full
# toolchain has been verified to work on Node 20.x regardless of the warning.
engine-strict=false
